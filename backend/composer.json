{
    "name": "lemes/clinica-pediatrica-backend",
    "type": "project",
    "description": "Clínica Pediátrica - Backend Symfony",
    "require": {
        "php": "^8.2",
        "symfony/framework-bundle": "7.*",
        "symfony/http-foundation": "7.*",
        "symfony/routing": "7.*",
        "symfony/http-kernel": "7.*",
        "symfony/dependency-injection": "7.*",
        "symfony/config": "7.*",
        "symfony/console": "7.*",
        "symfony/maker-bundle": "^1.50",
        "doctrine/orm": "^2.16",
        "doctrine/doctrine-bundle": "^2.10",
        "symfony/var-dumper": "7.*",
        "firebase/php-jwt": "^6.8"
    },
    "require-dev": {
        "symfony/debug-bundle": "7.*"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "scripts": {
        "serve": "symfony server:start",
        "dev": "symfony server:start -d",
        "db:migrate": "php bin/console doctrine:migrations:migrate"
    }
}
